use OxygenSuite\OxygenErgani\Http\Documents\WorkTime\DailyWorkTime;
use OxygenSuite\OxygenErgani\Http\Documents\WorkTime\DailyWorkTimeDrivers;
use OxygenSuite\OxygenErgani\Http\Documents\WorkTime\DailyWorkTimeRetrospective;
use OxygenSuite\OxygenErgani\Http\Documents\WorkTime\WeeklyWorkTime;
use OxygenSuite\OxygenErgani\Http\Documents\WorkTime\WorkTimeLeave;
use OxygenSuite\OxygenErgani\Http\Documents\WorkTime\WorkTimeLeaveCorrection;

/**
 * Parse XSD file and extract field names in order (recursively flattened).
 *
 * @return array<int, string>
 */
function parseXsdFields(string $xsdPath): array
{
    $xml = simplexml_load_file($xsdPath);
    $xml->registerXPathNamespace('xs', 'http://www.w3.org/2001/XMLSchema');

    // Build a map of named complex types
    /** @var array<string, SimpleXMLElement> $typeMap */
    $typeMap = [];
    foreach ($xml->xpath('//xs:complexType[@name]') as $complexType) {
        $typeMap[(string) $complexType['name']] = $complexType;
    }

    // Find the root element and start recursion from its type
    $rootElements = $xml->xpath('/xs:schema/xs:element[@type]');

    if (empty($rootElements)) {
        return [];
    }

    $rootType = (string) $rootElements[0]['type'];

    return collectFields($typeMap, $rootType);
}

/**
 * Recursively collect leaf field names from a complex type.
 *
 * @param array<string, SimpleXMLElement> $typeMap
 *
 * @return array<int, string>
 */
function collectFields(array $typeMap, string $typeName): array
{
    if (!isset($typeMap[$typeName])) {
        return [];
    }

    $type = $typeMap[$typeName];
    $type->registerXPathNamespace('xs', 'http://www.w3.org/2001/XMLSchema');
    $elements = $type->xpath('xs:sequence/xs:element');

    $fields = [];

    foreach ($elements as $element) {
        $name = (string) $element['name'];
        $refType = (string) $element['type'];

        // If the element references a local complex type, recurse into it
        if ($refType !== '' && isset($typeMap[$refType])) {
            $fields = array_merge($fields, collectFields($typeMap, $refType));
        } else {
            // Leaf field — collect its name
            $fields[] = $name;
        }
    }

    return $fields;
}

// Load .env file from project root
$envFile = loadEnvFile(__DIR__ . '/../.env');

$xsdDir = __DIR__ . '/../xsd';

// Schema map: grouped by XSD. Each group has an XSD path and an array of document classes.
// Documents sharing the same XSD are grouped together so their API fields can be unioned.
$schemaMap = [
    'WorkCard' => [
        'xsd' => 'Card_v1.xsd',
        'documents' => [
            'WorkCard' => WorkCard::class,
        ],
    ],
    'WTO' => [
        'xsd' => 'WTO_v2.xsd',
        'documents' => [
            'DailyWorkTime' => DailyWorkTime::class,
            'DailyWorkTimeA' => DailyWorkTimeRetrospective::class,
            'DailyWorkTimeD' => DailyWorkTimeDrivers::class,
            'WorkTimeLeave' => WorkTimeLeave::class,
            'WorkTimeLeaveC' => WorkTimeLeaveCorrection::class,
            'Overtime' => WorkTimeOvertime::class,
            'OvertimeA' => WorkTimeOvertimeRetrospective::class,
            'OvertimeD' => WorkTimeOvertimeDrivers::class,
        ],
    ],
    'WeeklyWorkTime' => [
        'xsd' => 'WTO_Weekly_v1.xsd',
        'documents' => [
            'WeeklyWorkTime' => WeeklyWorkTime::class,
        ],
    ],
    'E3N' => [
        'xsd' => 'E3N_v1.xsd',
        'documents' => [
            'E3N' => HiringNew::class,
        ],
    ],
    'E3M' => [
        'xsd' => 'E3M_v1.xsd',
        'documents' => [
            'E3M' => HiringModification::class,
        ],
    ],
    'E3D' => [
        'xsd' => 'E3D_v1.xsd',
        'documents' => [
            'E3D' => HiringDeletion::class,
        ],
    ],
    'E3PD' => [
        'xsd' => 'E3PD_v1.xsd',
        'documents' => [
            'E3PD' => HiringWithLending::class,
        ],
    ],
    'E5N' => [
        'xsd' => 'E5N_v1.xsd',
        'documents' => [
            'E5N' => VoluntaryResignation::class,
        ],
    ],
    'E5O' => [
        'xsd' => 'E5O_v1.xsd',
        'documents' => [
            'E5O' => ResignationNotification::class,
        ],
    ],
    'E5AO' => [
        'xsd' => 'E5AO_v1.xsd',
        'documents' => [
            'E5AO' => ResignationAfterNotification::class,
        ],
    ],
    'E5D' => [
