#!/usr/bin/env php
<?php

/**
 * CLI tool to compare document schemas against local XSD files.
 *
 * Documents sharing the same XSD are grouped together, and their API fields
 * are unioned for a single comparison per XSD.
 *
 * Usage:
 *   composer schema:check E6LT
 *   composer schema:check WTO           (checks all 8 WTO documents)
 *   composer schema:check DailyWorkTime (resolves to WTO group)
 *   composer schema:check --all
 *   composer schema:check --list
 *   composer schema:check --all --show-order
 *   composer schema:check --all --errors-only
 *   composer schema:check --coverage
 *   composer schema:check --all --fresh
 *
 * Configuration (in order of priority):
 *   1. .env file in project root
 *   2. Environment variables
 *
 * Required variables:
 *   ERGANI_USERNAME  - ERGANI username
 *   ERGANI_PASSWORD  - ERGANI password
 *   ERGANI_ENV       - Environment: 'test' or 'production' (default: test)
 */

require __DIR__ . '/bootstrap.php';

use OxygenSuite\OxygenErgani\Cache\FileCache;
use OxygenSuite\OxygenErgani\Exceptions\ErganiException;
