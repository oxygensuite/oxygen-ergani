    'Internship' => [
        'xsd' => 'E35_v2.xsd',
        'documents' => [
            'Internship' => Internship::class,
        ],
    ],
];

// Build name index: maps every valid CLI name (group or document) to its group key
$nameIndex = [];

foreach ($schemaMap as $groupName => $group) {
    $nameIndex[$groupName] = $groupName;

    foreach (array_keys($group['documents']) as $docName) {
        if ($docName !== $groupName) {
            $nameIndex[$docName] = $groupName;
        }
    }
}

$args = array_slice($argv, 1);

if (empty($args) || in_array('--help', $args) || in_array('-h', $args)) {
    echo "Usage: composer schema:check <name>\n";
    echo "       composer schema:check --all\n";
    echo "       composer schema:check --list\n";
    echo "       composer schema:check --all --show-order\n";
    echo "       composer schema:check --all --errors-only\n";
    echo "       composer schema:check --coverage\n";
    echo "       composer schema:check --all --fresh\n\n";
    echo "Names can be group names (e.g. WTO) or document names (e.g. DailyWorkTime).\n";
    echo "Document names resolve to their group.\n\n";
    echo "Available names:\n";
    foreach ($nameIndex as $name => $group) {
        if ($name === $group) {
            echo "  - $name\n";
        } else {
            echo "  - $name → $group\n";
        }
    }
    exit(0);
}

if (in_array('--list', $args)) {
    echo "Available schemas for comparison:\n\n";
    foreach ($schemaMap as $groupName => $group) {
        $xsdLabel = $group['xsd'] ? "xsd/{$group['xsd']}" : '(no XSD)';
        $docNames = array_keys($group['documents']);
        $isMulti = count($docNames) > 1;

        echo "  \033[1m$groupName\033[0m ($xsdLabel)\n";

        if ($isMulti) {
            echo '    Documents: ' . implode(', ', $docNames) . "\n";
        } else {
            $docClass = reset($group['documents']);
            echo "    Class: $docClass\n";
        }

        echo "\n";
    }
    exit(0);
}

$cache = new FileCache();
$cacheTtl = 86400;

if (in_array('--fresh', $args)) {
    foreach ($schemaMap as $group) {
        foreach ($group['documents'] as $docClass) {
            $cache->delete('cli:schema:' . (new ReflectionClass($docClass))->getShortName());
        }
    }
    $cache->delete('cli:submissions');
}

setupAuth($envFile);

$isCoverage = in_array('--coverage', $args);

if ($isCoverage) {
    echo "Fetching submissions list from API...\n\n";

    // Fetch available submissions from the API (cached for 1 day)
    $cacheKey = 'cli:submissions';
    $submissions = $cache->get($cacheKey);

    if ($submissions === null) {
        $submissions = (new LookupSubmissions())->handle();
        $cache->set($cacheKey, $submissions, $cacheTtl);
    }

    // Build a map of API codes from the submissions list
    /** @var array<string, string> $apiCodes code => description */
    $apiCodes = [];
    foreach ($submissions as $submission) {
        $apiCodes[$submission['code']] = $submission['description'];
    }

    // Build a map of our document action codes via reflection
    /** @var array<string, string> $ourCodes action => docName */
    $ourCodes = [];
    foreach ($schemaMap as $groupName => $group) {
        foreach ($group['documents'] as $docName => $docClass) {
            $ref = new ReflectionMethod($docClass, 'action');
            $obj = new $docClass();
            $action = $ref->invoke($obj);
            $ourCodes[$action] = $docName;
        }
    }

    // Cross-reference
    $covered = [];
    $notCovered = [];
    $notInApi = [];

    foreach ($apiCodes as $code => $description) {
        if (isset($ourCodes[$code])) {
            $covered[$code] = ['description' => $description, 'docName' => $ourCodes[$code]];
        } else {
            $notCovered[$code] = $description;
        }
    }

    foreach ($ourCodes as $action => $docName) {
        if (!isset($apiCodes[$action])) {
            $notInApi[$action] = $docName;
        }
    }

    // Output
    echo "\033[1mAPI Coverage Report\033[0m\n";
    echo str_repeat('=', 40) . "\n\n";

    echo "\033[32m✓ Covered: " . count($covered) . '/' . count($apiCodes) . " API submissions\033[0m\n";
    foreach ($covered as $code => $info) {
        echo "    $code → {$info['docName']}\n";
    }

    if (count($notCovered) > 0) {
        echo "\n\033[33m⚠ Not covered: " . count($notCovered) . " API submissions\033[0m\n";
        foreach ($notCovered as $code => $description) {
            echo "    $code — $description\n";
        }
    }

    if (count($notInApi) > 0) {
        echo "\n\033[36mℹ Our documents not in submissions list: " . count($notInApi) . "\033[0m\n";
        foreach ($notInApi as $action => $docName) {
            echo "    $action ($docName)\n";
        }
    }

    echo "\n";
    exit(count($notCovered) > 0 ? 1 : 0);
}

$showOrder = in_array('--show-order', $args);
$errorsOnly = in_array('--errors-only', $args);
$groupsToCheck = [];

if (in_array('--all', $args)) {
    $groupsToCheck = array_keys($schemaMap);
} else {
    foreach ($args as $arg) {
        if (str_starts_with($arg, '-')) {
            continue;
        }

        if (!isset($nameIndex[$arg])) {
            echo "\033[31mError: Unknown name '$arg'\033[0m\n";
            echo "Use --list to see available schemas.\n";
            exit(1);
        }

        $resolvedGroup = $nameIndex[$arg];

        if (!in_array($resolvedGroup, $groupsToCheck)) {
            if ($arg !== $resolvedGroup) {
                echo "\033[36mℹ '$arg' → group '$resolvedGroup'\033[0m\n";
            }
            $groupsToCheck[] = $resolvedGroup;
        }
    }
}

if (empty($groupsToCheck)) {
    echo "No schemas to check. Use --help for usage.\n";
    exit(1);
}

/**
 * Fetch API schema for a document class and extract field names.
 *
 * @param class-string $docClass
 *
 * @return array<int, string>
 * @throws ReflectionException
 * @throws \Psr\SimpleCache\InvalidArgumentException
 * @throws ErganiException
 */
function getApiFields(string $docClass, FileCache $cache, int $cacheTtl): array
{
    $cacheKey = 'cli:schema:' . (new ReflectionClass($docClass))->getShortName();
    $cached = $cache->get($cacheKey);

    if ($cached !== null) {
        return $cached;
    }

    /** @var Documents $document */
    $document = new $docClass();
    $schema = $document->schema();

    $fields = [];

    foreach ($schema['propertiesInfo'] as $prop) {
        $fields[] = $prop['name'];
    }

    $cache->set($cacheKey, $fields, $cacheTtl);

    return $fields;
}

$hasIssues = false;
$checkedCount = 0;
$skippedCount = 0;

foreach ($groupsToCheck as $groupName) {
    $group = $schemaMap[$groupName];
    $xsd = $group['xsd'];
    $documents = $group['documents'];
    $isMulti = count($documents) > 1;
    $groupHasIssues = false;

    // Buffer output so we can suppress clean groups when --errors-only is active
    ob_start();

    $xsdLabel = $xsd ? "xsd/$xsd" : 'no local XSD';
    echo "\n\033[1m$groupName\033[0m ($xsdLabel)\n";

    if ($isMulti) {
        echo '  Documents: ' . implode(', ', array_keys($documents)) . "\n";
    }

    echo str_repeat('-', strlen($groupName) + strlen($xsdLabel) + 3) . "\n";

    try {
        // Fetch API fields for each document and build the union
        $unionFields = [];

        foreach ($documents as $docName => $docClass) {
            $apiFields = getApiFields($docClass, $cache, $cacheTtl);

            foreach ($apiFields as $field) {
                if (!in_array($field, $unionFields)) {
                    $unionFields[] = $field;
                }
            }
        }

        if ($xsd === null) {
            $groupHasIssues = true;
            echo "\033[33m⚠ No XSD file — skipping field comparison\033[0m\n";
            echo '  API fields (' . count($unionFields) . '): ' . implode(', ', $unionFields) . "\n";

            $output = ob_get_clean();
            $hasIssues = true;

            if (!$errorsOnly || $groupHasIssues) {
                echo $output;
            } else {
                $skippedCount++;
            }
            $checkedCount++;

            continue;
        }

        $xsdPath = $xsdDir . '/' . $xsd;

        if (!file_exists($xsdPath)) {
            $groupHasIssues = true;
            echo "\033[31m✗ XSD file not found: $xsdPath\033[0m\n";

            $output = ob_get_clean();
            $hasIssues = true;

            if (!$errorsOnly || $groupHasIssues) {
                echo $output;
            } else {
                $skippedCount++;
            }
            $checkedCount++;

            continue;
        }

        $xsdFields = parseXsdFields($xsdPath);

        $inXsdNotApi = array_values(array_diff($xsdFields, $unionFields));
        $inApiNotXsd = array_values(array_diff($unionFields, $xsdFields));
        $matched = array_values(array_intersect($unionFields, $xsdFields));

        $countLabel = $isMulti
            ? count($matched) . ' (union of ' . count($documents) . ' API schemas)'
            : (string) count($matched);

        echo "\033[32m✓ Fields match: $countLabel\033[0m\n";

        if (count($inApiNotXsd) > 0) {
            $groupHasIssues = true;
            echo "\033[33m⚠ In API but not in XSD: " . count($inApiNotXsd) . "\033[0m\n";
            foreach ($inApiNotXsd as $field) {
                echo "    + $field\n";
            }
        }

        if (count($inXsdNotApi) > 0) {
            $groupHasIssues = true;
            echo "\033[31m✗ In XSD but not in API: " . count($inXsdNotApi) . "\033[0m\n";
            foreach ($inXsdNotApi as $field) {
                echo "    - $field\n";
            }
        }

        // Order comparison only makes sense for single-document groups
        if (!$isMulti && count($inApiNotXsd) === 0 && count($inXsdNotApi) === 0) {
            if ($unionFields === $xsdFields) {
                echo "\033[32m✓ Order matches\033[0m\n";
            } elseif ($showOrder) {
                echo "\033[36mℹ Field order differs\033[0m\n";
                echo '    API: ' . implode(', ', $unionFields) . "\n";
                echo '    XSD: ' . implode(', ', $xsdFields) . "\n";
            } else {
                echo "\033[36mℹ Field order differs (use --show-order to display)\033[0m\n";
            }
        }
    } catch (Exception $e) {
        $groupHasIssues = true;
        echo "\033[31m✗ Error: {$e->getMessage()}\033[0m\n";
    }

    $output = ob_get_clean();

    if ($groupHasIssues) {
        $hasIssues = true;
    }

    if (!$errorsOnly || $groupHasIssues) {
        echo $output;
    } else {
        $skippedCount++;
    }
    $checkedCount++;
}

if ($errorsOnly && $skippedCount > 0) {
    echo "\n\033[32m✓ $skippedCount/$checkedCount schemas passed (hidden)\033[0m\n";
}

echo "\n";
exit($hasIssues ? 1 : 0);
