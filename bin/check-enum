#!/usr/bin/env php
<?php

/**
 * CLI tool to compare enums against the live ERGANI API.
 *
 * Usage:
 *   composer enum:check WorkCardDelayReason
 *   composer enum:check --all
 *   composer enum:check --list
 *   composer enum:check --all --fresh
 *
 * Configuration (in order of priority):
 *   1. .env file in project root
 *   2. Environment variables
 *
 * Required variables:
 *   ERGANI_USERNAME  - ERGANI username
 *   ERGANI_PASSWORD  - ERGANI password
 *   ERGANI_ENV       - Environment: 'test' or 'production' (default: test)
 */

require __DIR__ . '/bootstrap.php';

use OxygenSuite\OxygenErgani\Cache\FileCache;
use OxygenSuite\OxygenErgani\Enums\WorkCardDelayReason;
use OxygenSuite\OxygenErgani\Enums\WorkTimeType;
use OxygenSuite\OxygenErgani\Http\Services\ParameterLookup;
use OxygenSuite\OxygenErgani\Responses\ParameterCollection;

// Load .env file from project root
$envFile = loadEnvFile(__DIR__ . '/../.env');

// Map of enum short names to [ParameterLookup constant, full enum class]
$enumMap = [
    'WorkCardDelayReason' => [
        ParameterLookup::WORK_CARD_DELAY_REASON,
        WorkCardDelayReason::class,
    ],
    'WorkTimeType' => [
        ParameterLookup::WORK_TIME_TYPE,
        WorkTimeType::class,
    ],
];

$args = array_slice($argv, 1);

if (empty($args) || in_array('--help', $args) || in_array('-h', $args)) {
    echo "Usage: composer enum:check <enum-name>\n";
    echo "       composer enum:check --all\n";
    echo "       composer enum:check --list\n";
    echo "       composer enum:check --all --fresh\n\n";
    echo "Available enums:\n";
    foreach (array_keys($enumMap) as $name) {
        echo "  - {$name}\n";
    }
    exit(0);
}

if (in_array('--list', $args)) {
    echo "Available enums for comparison:\n\n";
    foreach ($enumMap as $name => [$paramType, $enumClass]) {
        echo "  {$name}\n";
        echo "    Parameter: {$paramType}\n";
        echo "    Class: {$enumClass}\n\n";
    }
    exit(0);
}

$enumsToCheck = [];

if (in_array('--all', $args)) {
    $enumsToCheck = array_keys($enumMap);
} else {
    foreach ($args as $arg) {
        if (str_starts_with($arg, '-')) {
            continue;
        }
        if (!isset($enumMap[$arg])) {
            echo "\033[31mError: Unknown enum '{$arg}'\033[0m\n";
            echo "Use --list to see available enums.\n";
            exit(1);
        }
        $enumsToCheck[] = $arg;
    }
}

if (empty($enumsToCheck)) {
    echo "No enums to check. Use --help for usage.\n";
    exit(1);
}

setupAuth($envFile);

$cache = new FileCache();
$cacheTtl = 86400;

if (in_array('--fresh', $args)) {
    foreach ($enumMap as [$paramType, $enumClass]) {
        $cache->delete("cli:enum:{$paramType}");
    }
}

/**
 * Fetch parameters from API (cached for 1 day).
 */
function getParameters(string $type, FileCache $cache, int $cacheTtl): ParameterCollection
{
    $cacheKey = "cli:enum:{$type}";
    $cached = $cache->get($cacheKey);

    if ($cached !== null) {
        return $cached;
    }

    $result = (new ParameterLookup())->handle($type);
    $cache->set($cacheKey, $result, $cacheTtl);

    return $result;
}

/**
 * Compare enum values against API values.
 *
 * @param class-string<BackedEnum> $enumClass
 *
 * @return array{missing_in_enum: array<string>, extra_in_enum: array<string>, matched: array<string>}
 */
function compareWithEnum(string $paramType, string $enumClass, FileCache $cache, int $cacheTtl): array
{
    $apiValues = array_keys(getParameters($paramType, $cache, $cacheTtl)->all());
    $enumValues = array_map(
        fn(BackedEnum $case) => (string) $case->value,
        $enumClass::cases(),
    );

    return [
        'missing_in_enum' => array_values(array_diff($apiValues, $enumValues)),
        'extra_in_enum' => array_values(array_diff($enumValues, $apiValues)),
        'matched' => array_values(array_intersect($apiValues, $enumValues)),
    ];
}

$hasIssues = false;

foreach ($enumsToCheck as $enumName) {
    [$paramType, $enumClass] = $enumMap[$enumName];

    echo "\n\033[1m{$enumName}\033[0m\n";
    echo str_repeat('-', strlen($enumName)) . "\n";

    try {
        $result = compareWithEnum($paramType, $enumClass, $cache, $cacheTtl);

        $matchedCount = count($result['matched']);
        $missingCount = count($result['missing_in_enum']);
        $extraCount = count($result['extra_in_enum']);

        echo "\033[32m✓ Matched: {$matchedCount}\033[0m\n";

        if ($missingCount > 0) {
            $hasIssues = true;
            echo "\033[33m⚠ Missing in enum: {$missingCount}\033[0m\n";
            foreach ($result['missing_in_enum'] as $code) {
                $param = getParameters($paramType, $cache, $cacheTtl)->find($code);
                $desc = $param ? " ({$param->description})" : '';
                echo "    - {$code}{$desc}\n";
            }
        }

        if ($extraCount > 0) {
            $hasIssues = true;
            echo "\033[31m✗ Extra in enum (not in API): {$extraCount}\033[0m\n";
            foreach ($result['extra_in_enum'] as $code) {
                echo "    - {$code}\n";
            }
        }

        if ($missingCount === 0 && $extraCount === 0) {
            echo "\033[32m✓ Enum is in sync with API\033[0m\n";
        }
    } catch (\Exception $e) {
        $hasIssues = true;
        echo "\033[31m✗ Error: {$e->getMessage()}\033[0m\n";
    }
}

echo "\n";
exit($hasIssues ? 1 : 0);
