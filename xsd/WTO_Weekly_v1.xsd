<xs:schema xmlns="http://www.yeka.gr/WTO" xml:lang="gr" attributeFormDefault="unqualified" targetNamespace="http://www.yeka.gr/WTO" xmlns:xs="http://www.w3.org/2001/XMLSchema">
    <xs:complexType name="ErgazomenosWTOAnalyticType">
        <xs:sequence>
			<xs:element name="f_type">
                <xs:annotation><xs:documentation>ΤΥΠΟΣ ΑΝΑΛΥΤΙΚΗΣ ΕΓΓΡΑΦΗΣ - ΚΩΔΙΚΟΣ</xs:documentation></xs:annotation>
				 <xs:simpleType>
                    <xs:restriction base="xs:string">
                        <xs:maxLength value="10" />
                        <xs:minLength value="1"/>
                    </xs:restriction>
                </xs:simpleType>
			</xs:element>
              <xs:element name="f_from" nillable="false">
                <xs:annotation><xs:documentation>ΩΡΑ ΑΠΟ (HH24:MM)</xs:documentation></xs:annotation>
                <xs:simpleType>
                    <xs:restriction base="xs:string">
                        <xs:pattern value="((([0-1][0-9]|2[0-3]):([0-5][0-9]))|([ ]*))"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
			<xs:element name="f_to" nillable="false">
                <xs:annotation><xs:documentation>ΩΡΑ ΕΩΣ (HH24:MM)</xs:documentation></xs:annotation>
                <xs:simpleType>
                    <xs:restriction base="xs:string">
                        <xs:pattern value="((([0-1][0-9]|2[0-3]):([0-5][0-9]))|([ ]*))"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
	<xs:complexType name="ErgazomenosWTOAnalyticsType">
		<xs:sequence>
			<xs:element name="ErgazomenosWTOAnalytics" type="ErgazomenosWTOAnalyticType"  minOccurs="1"  maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation>ΣΤΟΙΧΕΙΑ ΟΡΓΑΝΩΣΗΣ ΧΡΟΝΟΥ ΕΡΓΑΣΙΑΣ</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="ErgazomenosWTOType">
        <xs:sequence>
            <xs:element name="f_afm" nillable="false">
                <xs:annotation>
                    <xs:documentation>ΑΡΙΘΜΟΣ ΦΟΡΟΛΟΓΙΚΟΥ ΜΗΤΡΩΟΥ (Α.Φ.Μ.)</xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                    <xs:restriction base="xs:string">
                        <xs:pattern value="([0-9]){9}" />
                        <xs:length value="9" />
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element name="f_eponymo" nillable="false">
                <xs:annotation>
                    <xs:documentation>ΕΠΩΝΥΜΟ</xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                    <xs:restriction base="xs:string">
                        <xs:maxLength value="50" />
                        <xs:minLength value="1"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element name="f_onoma" nillable="false">
                <xs:annotation>
                    <xs:documentation>ΟΝΟΜΑ</xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                    <xs:restriction base="xs:string">
                        <xs:maxLength value="30" />
                        <xs:minLength value="1"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element> 
			<xs:element name="f_day" nillable="false">
                <xs:annotation><xs:documentation>ΗΜΕΡΑ - (0) ΚΥΡΙΑΚΗ - (1) ΔΕΥΤΕΡΑ - (2) ΤΡΙΤΗ - (3) ΤΕΤΑΡΤΗ - (4) ΠΕΜΠΤΗ - (5) ΠΑΡΑΣΚΕΥΗ - (6) ΣΑΒΒΑΤΟ </xs:documentation></xs:annotation>
                <xs:simpleType>
                    <xs:restriction base="xs:string">
						<xs:enumeration value=""/>
                        <xs:enumeration value="0"/>
                        <xs:enumeration value="1"/>
                        <xs:enumeration value="2"/>
                        <xs:enumeration value="3"/>
                        <xs:enumeration value="4"/>
                        <xs:enumeration value="5"/>
                        <xs:enumeration value="6"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
			<xs:element name="ErgazomenosAnalytics" type="ErgazomenosWTOAnalyticsType">
        		<xs:annotation>
        			<xs:documentation>ΟΡΓΑΝΩΣΗΣ ΧΡΟΝΟΥ ΕΡΓΑΣΙΑΣ ΕΡΓΑΖΟΜΕΝΟΥ</xs:documentation>
        		</xs:annotation>
        	</xs:element>    			
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="ErgazomenoiWTOType">
		<xs:sequence>
			<xs:element name="ErgazomenoiWTO" type="ErgazomenosWTOType"  minOccurs="1"  maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation>ΣΤΟΙΧΕΙΑ ΕΡΓΑΖΟΜΕΝΩΝ ΟΡΓΑΝΩΣΗΣ ΧΡΟΝΟΥ ΕΡΓΑΣΙΑΣ</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
